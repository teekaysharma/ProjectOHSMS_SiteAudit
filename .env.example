# =============================================================================
# OHS Management System - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Security & Authentication
# -----------------------------------------------------------------------------

# JWT Secret - Used to sign authentication tokens
# Generate a strong random string (at least 32 characters recommended)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-strong-random-secret-min-32-chars

# -----------------------------------------------------------------------------
# OPTIONAL: Server Configuration
# -----------------------------------------------------------------------------

# Port for the Express server to listen on
# Default: 3000
PORT=3000

# Node environment mode
# Values: development | production | test
# Default: production (when not specified)
NODE_ENV=development

# -----------------------------------------------------------------------------
# OPTIONAL: Frontend API Configuration (for production builds)
# -----------------------------------------------------------------------------

# Base URL for API requests from the frontend
# In production, set this to your deployed backend URL
# Default: http://localhost:3000
# VITE_API_BASE_URL=https://your-api-domain.com

# -----------------------------------------------------------------------------
# OPTIONAL: Rate Limiting & Security
# -----------------------------------------------------------------------------

# Maximum API requests per window (15 minutes)
# Default: 300
# RATE_LIMIT_MAX=300

# -----------------------------------------------------------------------------
# OPTIONAL: Data Storage
# -----------------------------------------------------------------------------

# Directory for server-side data storage
# Default: ./server-data (relative to server.js)
# DATA_DIR=/path/to/custom/data/directory

# =============================================================================
# Deployment-Specific Values
# =============================================================================

# For Render Deployment:
# - JWT_SECRET: Auto-generated (generateValue: true in render.yaml)
# - PORT: 3000
# - NODE_ENV: production

# For Railway Deployment:
# - Set JWT_SECRET in Railway dashboard
# - PORT is auto-assigned by Railway

# For Docker Deployment:
# - JWT_SECRET: Set via environment or .env file
# - PORT: 3000 (mapped to host)
# - NODE_ENV: production
