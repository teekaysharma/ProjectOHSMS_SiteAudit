{
  "name": "vite-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:localhost": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "preview:localhost": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "deploy:localhost": "npm run build && npm run preview:localhost",
    "start:api": "node server.js",
    "start:mvp": "npm run build && npm run start:api",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^3.7.1",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3"
  }
}
