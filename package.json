{
  "name": "ohs-audit-tool",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:localhost": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "preview:localhost": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "deploy:localhost": "npm run build && npm run preview:localhost",
    "start": "node server.js",
    "test": "node --test tests/api.test.js"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bytes": "^3.1.2",
    "chart.js": "^3.7.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2"
  }
}
